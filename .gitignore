# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin_kvnode
test_kvnode

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# 数据库生成的数据文件（非常重要！）
data/
*.sst
*.log

# Local benchmark helper scripts
scripts/*
!scripts/run_functional_tests.sh
!scripts/run_recovery_tests.sh
!scripts/run_diagnostic_suite.sh
!scripts/smoke_api_test.sh
!scripts/run_recovery_quant_tests.sh
!scripts/run_read_mode_comparison_suite.sh
!scripts/run_compaction_ablation_suite.sh
!scripts/run_request_match_experiment.sh

# Benchmark result logs are committed with formal result sets
!benchmark_results/**/*.log

# IDE 相关
.idea/
.vscode/
